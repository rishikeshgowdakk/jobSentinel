# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Database Configuration
DB_NAME=jobsentinel
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=recipient_email@gmail.com

# Google Calendar (JSON Credentials path)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Scraper Settings
SCRAPE_INTERVAL=60
JOB_KEYWORDS="Software Engineer, Python Developer"
JOB_LOCATIONS="Remote, United States"

# Resume Settings
MASTER_RESUME_PATH=master_resume.md
OUTPUT_DIR=output_resumes
