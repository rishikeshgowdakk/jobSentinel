# Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key

# Database — leave blank to use SQLite (default)
# Uncomment below for PostgreSQL:
# DB_NAME=jobsentinel
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# Email Notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=recipient_email@gmail.com

# Scraper Settings
SCRAPE_INTERVAL=60
JOB_KEYWORDS=Software Engineer, Python Developer
JOB_LOCATIONS=Remote, United States
